# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
indent_style = space
charset = utf-8
trim_trailing_whitespace = true

# JavaScript, JSX, TypeScript
[*.{js,jsx,ts,tsx,mts,mjs}]
indent_size = 2
max_line_length = 100

# CSS, SCSS, LESS
[*.{css,scss,less}]
indent_size = 2

# HTML, XML
[*.{html,xml,svg}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# YAML
[*.{yaml,yml}]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Shell scripts
[*.{sh,bash}]
indent_size = 2

# Makefile
[Makefile]
indent_style = tab
